{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "DATABASE_URL": "postgresql://user:password@localhost:5432/lockedin"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "DATABASE_URL": "postgresql://user:password@localhost:5432/lockedin"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "DATABASE_URL": "postgresql://user:password@localhost:5432/lockedin"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
